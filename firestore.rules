rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /articles/{articleId} {
      allow read, write: if true;

      match /comments/{commentId} {
        allow read, write: if true;
      }
    }
    match /fixtures/{fixtureId} {
      allow read, write: if true;
    }
    match /comments/{commentId} {
      allow read, write: if true;
    }
  }
}

